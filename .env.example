# Wanderly iOS - Environment Variables
# Copy this file to .env and fill in your values

# Gemini API (for AI parsing)
GEMINI_API_KEY=AIzaxxxxx

# Google Places API (for place matching & details)
GOOGLE_PLACES_API_KEY=AIzaxxxxx

# Supabase (backend database & storage)
SUPABASE_URL=https://yourproject.supabase.co
WANDERLY_API_URL=https://yourproject.supabase.co/functions/v1/wanderly-api

# Supabase Edge Function secrets (server-side only; never ship in app)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----..."

# Privy (authentication)
PRIVY_APP_ID=clxxxxx
PRIVY_APP_CLIENT_ID=clxxxxx
